{
  "name": "mem-extract",
  "version": "1.0.0",
  "description": "Generate persistent Markdown memory files for AI coding agents.",
  "type": "module",
  "bin": {
    "mem-extract": "./dist/index.js",
    "memory-inheritance": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "npm run build && node --test"
  },
  "keywords": [
    "ai",
    "coding-agent",
    "context",
    "memory",
    "developer-tools"
  ],
  "author": "Yuhang Zhao",
  "license": "MIT",
  "dependencies": {
    "minimist": "^1.2.8"
  },
  "devDependencies": {
    "@types/minimist": "^1.2.5",
    "@types/node": "^18.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
